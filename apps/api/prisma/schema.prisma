generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(150)
  email      String   @unique @db.VarChar(150)
  password   String   @db.VarChar(255)
  role       String?  @db.VarChar(100)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  incoming_documents IncomingDocument[]
}

model DocumentType {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  incoming_documents IncomingDocument[]
}

model Silo {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  receipt_invoices        ReceiptInvoice[]
  receipt_dos             ReceiptDo[]
  receipt_pls             ReceiptPl[]
  receipt_voucherPayments ReceiptVoucherPayment[]
}

model Sender {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  incoming_documents IncomingDocument[]
}

model Vendor {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(150)
  name        String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  receipt_invoices ReceiptInvoice[]
  receipt_dos      ReceiptDo[]
}

model Bank {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  receipt_voucherPayments ReceiptVoucherPayment[]
}

model IncomingDocument {
  id                    String   @id @default(uuid()) @db.Uuid
  user_id               String   @db.Uuid
  document_receipt_date DateTime @db.Date
  title                 String?  @db.VarChar(150)   // baru
  document_type_id      String   @db.Uuid
  sender_id             String   @db.Uuid
  qty                   Int?
  note                  String?  @db.VarChar(255)   // baru
  description           String?  @db.VarChar(255)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  user          User         @relation(fields: [user_id], references: [id])
  document_type DocumentType @relation(fields: [document_type_id], references: [id])
  sender        Sender       @relation(fields: [sender_id], references: [id])

  receipt_invoices        ReceiptInvoice[]
  receipt_dos             ReceiptDo[]
  receipt_pls             ReceiptPl[]
  receipt_voucherPayments ReceiptVoucherPayment[]
  receipt_otherDocuments  ReceiptOtherDocument[]
}

model ReceiptInvoice {
  id                   String    @id @default(uuid()) @db.Uuid
  incoming_document_id String    @db.Uuid
  silo_id              String    @db.Uuid
  no_invoice           String?   @db.VarChar(150)
  no_po                String?   @db.VarChar(150)
  vendor_id            String    @db.Uuid
  scan_date            DateTime? @db.Date
  upload_date          DateTime? @db.Date
  description          String?   @db.VarChar(255)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
  vendor            Vendor           @relation(fields: [vendor_id], references: [id])
}

model ReceiptDo {
  id                   String    @id @default(uuid()) @db.Uuid
  incoming_document_id String    @db.Uuid
  no_do                String    @db.VarChar(150)
  no_pid               String    @db.VarChar(150)
  silo_id              String    @db.Uuid
  vendor_id            String    @db.Uuid
  scan_date            DateTime? @db.Date
  upload_date          DateTime? @db.Date
  description          String?   @db.VarChar(255)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
  vendor            Vendor           @relation(fields: [vendor_id], references: [id])
}

model ReceiptPl {
  id                   String    @id @default(uuid()) @db.Uuid
  incoming_document_id String    @db.Uuid
  silo_id              String    @db.Uuid
  no_pl                String    @db.VarChar(150)
  ship_ref             String    @db.VarChar(150)
  scan_date            DateTime? @db.Date
  upload_date          DateTime? @db.Date
  description          String?   @db.VarChar(255)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
}

model ReceiptVoucherPayment {
  id                   String    @id @default(uuid()) @db.Uuid
  incoming_document_id String    @db.Uuid
  silo_id              String    @db.Uuid
  bank_id              String    @db.Uuid
  month                Int
  year                 Int
  scan_date            DateTime? @db.Date
  upload_date          DateTime? @db.Date
  description          String?   @db.VarChar(255)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
  bank              Bank             @relation(fields: [bank_id], references: [id])
}

model ReceiptOtherDocument {
  id                   String    @id @default(uuid()) @db.Uuid
  incoming_document_id String    @db.Uuid
  no_document          String    @db.VarChar(150)
  scan_date            DateTime? @db.Date
  upload_date          DateTime? @db.Date
  description          String?   @db.VarChar(255)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
}
