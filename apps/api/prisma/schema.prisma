generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  incoming_documents IncomingDocument[]
}

model DocumentType {
  id          String   @id @default(uuid())
  title       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  incoming_documents IncomingDocument[]
}

model Silo {
  id          String   @id @default(uuid())
  title       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  receipt_invoices        ReceiptInvoice[]
  receipt_dos             ReceiptDo[]
  receipt_pls             ReceiptPl[]
  receipt_voucherPayments ReceiptVoucherPayment[]
}

model Sender {
  id          String   @id @default(uuid())
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  incoming_documents IncomingDocument[]
}

model Vendor {
  id          String   @id @default(uuid())
  title       String
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  receipt_invoices ReceiptInvoice[]
  receipt_dos      ReceiptDo[]
}

model Bank {
  id          String   @id @default(uuid())
  title       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  receipt_voucherPayments ReceiptVoucherPayment[]
}

model IncomingDocument {
  id                    String   @id @default(uuid())
  user_id               String
  document_receipt_date DateTime
  title                 String?  // baru
  document_type_id      String
  sender_id             String
  qty                   Int?
  note                  String?  // baru
  description           String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  user          User         @relation(fields: [user_id], references: [id])
  document_type DocumentType @relation(fields: [document_type_id], references: [id])
  sender        Sender       @relation(fields: [sender_id], references: [id])

  receipt_invoices        ReceiptInvoice[]
  receipt_dos             ReceiptDo[]
  receipt_pls             ReceiptPl[]
  receipt_voucherPayments ReceiptVoucherPayment[]
  receipt_otherDocuments  ReceiptOtherDocument[]
}

model ReceiptInvoice {
  id                   String    @id @default(uuid())
  incoming_document_id String
  silo_id              String
  no_invoice           String?
  no_po                String?
  vendor_id            String
  scan_date            DateTime?
  upload_date          DateTime?
  description          String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
  vendor            Vendor           @relation(fields: [vendor_id], references: [id])
}

model ReceiptDo {
  id                   String    @id @default(uuid())
  incoming_document_id String
  no_do                String
  no_pid               String
  silo_id              String
  vendor_id            String
  scan_date            DateTime?
  upload_date          DateTime?
  description          String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
  vendor            Vendor           @relation(fields: [vendor_id], references: [id])
}

model ReceiptPl {
  id                   String    @id @default(uuid())
  incoming_document_id String
  silo_id              String
  no_pl                String
  ship_ref             String
  scan_date            DateTime?
  upload_date          DateTime?
  description          String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
}

model ReceiptVoucherPayment {
  id                   String    @id @default(uuid())
  incoming_document_id String
  silo_id              String
  bank_id              String
  month                Int
  year                 Int
  scan_date            DateTime?
  upload_date          DateTime?
  description          String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
  silo              Silo             @relation(fields: [silo_id], references: [id])
  bank              Bank             @relation(fields: [bank_id], references: [id])
}

model ReceiptOtherDocument {
  id                   String    @id @default(uuid())
  incoming_document_id String
  no_document          String
  scan_date            DateTime?
  upload_date          DateTime?
  description          String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  incoming_document IncomingDocument @relation(fields: [incoming_document_id], references: [id])
}
